---
import BaseLayout from '../layouts/BaseLayout.astro';
import pageData from '../data/pages/home.json';

const slideImageData = [
  {
    linked: true,
    src: '/Research/Job_Guarantee/JG_paper_cover.webp',
    alt: 'A Counter-Inflationary Job Guarantee for the UK',
  },
  {
    linked: false,
    srcset: '/images/marcos-luiz-photograph-R6xx6fnvPT8-unsplash-p-500.avif 500w, /images/marcos-luiz-photograph-R6xx6fnvPT8-unsplash-p-800.avif 800w, /images/marcos-luiz-photograph-R6xx6fnvPT8-unsplash-p-1080.avif 1080w, /images/marcos-luiz-photograph-R6xx6fnvPT8-unsplash-p-1600.avif 1600w, /images/hands-up.avif 2400w',
    sizes: '(max-width: 2400px) 100vw, 2400px',
    src: '/images/hands-up.avif',
    alt: '',
  },
  {
    linked: false,
    src: '/images/yp-hero.avif',
    alt: '',
  },
];
---

<BaseLayout title={pageData.meta.title} description={pageData.meta.description} currentPage="home">
  <header class="section_header102">
    <div class="header102_component">
      <div id="w-node-b45eb2d1-a9cb-fb6d-51c4-326d99812c3e-fa716c8e" class="header102_content">
        <div class="margin-bottom margin-small">
          <h1 class="heading-style-h1">{pageData.hero.heading}</h1>
        </div>
        <p class="text-size-medium-8 left-justified">{pageData.hero.tagline}</p>
      </div>
      <div data-delay="4000" data-animation="slide" class="header102_slider w-slider" data-autoplay="false" data-custom-autoplay="true" data-easing="ease" data-hide-arrows="false" data-disable-swipe="false" data-autoplay-limit="0" data-nav-spacing="3" data-duration="500" data-infinite="true" id="w-node-b45eb2d1-a9cb-fb6d-51c4-326d99812c4a-fa716c8e">
        <div class="header102_mask w-slider-mask">
          {pageData.hero.slides.map((slide, i) => {
            const img = slideImageData[i] || { linked: false, src: '', alt: '' };
            return (
              <div class="header102_slide w-slide">
                <div class="header102_slide-wrapper">
                  {slide.link_href ? (
                    <a href={slide.link_href} class="header102_slide-image-wrapper">
                      <img alt={img.alt} src={img.src} loading="lazy" class="header102_slide-image" />
                    </a>
                  ) : (
                    <div class="header102_slide-image-wrapper">
                      {img.srcset ? (
                        <img sizes={img.sizes} srcset={img.srcset} alt={img.alt} src={img.src} loading="lazy" class="header102_slide-image" />
                      ) : (
                        <img loading="lazy" src={img.src} alt={img.alt} class="header102_slide-image" />
                      )}
                    </div>
                  )}
                  <div class="header102_slide-content">
                    <div class="header102_slide-content-wrapper">
                      <div class="margin-bottom margin-tiny">
                        <div class="heading-style-h6">{slide.tag}</div>
                      </div>
                      {slide.link_href ? (
                        <p><a href={slide.link_href} class="text-style-link">{slide.link_label}</a></p>
                      ) : (
                        <p>{slide.text}</p>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
        <div class="header102_arrow is-left w-slider-arrow-left">
          <div class="product-header7_arrow-icon-copy w-embed">
            <svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3.31066 8.75001L9.03033 14.4697L7.96967 15.5303L0.439339 8.00001L7.96967 0.469676L9.03033 1.53034L3.31066 7.25001L15.5 7.25L15.5 8.75L3.31066 8.75001Z" fill="currentColor"></path>
            </svg>
          </div>
        </div>
        <div class="header102_arrow w-slider-arrow-right">
          <div class="product-header7_arrow-icon-copy w-embed">
            <svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12.6893 7.25L6.96967 1.53033L8.03033 0.469666L15.5607 8L8.03033 15.5303L6.96967 14.4697L12.6893 8.75H0.5V7.25H12.6893Z" fill="currentColor"></path>
            </svg>
          </div>
        </div>
        <div class="header102_slide-nav w-slider-nav w-slider-nav-invert w-round"></div>
      </div>
    </div>
  </header>

