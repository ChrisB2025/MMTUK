---
import { marked } from 'marked';
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/pages/privacy-policy.json';
---

<BaseLayout title="Privacy Policy" description="Our privacy policy." currentPage="privacy-policy">
<section class="section_content28">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="content28_component">
                <div id="w-node-be7cecb1-ce71-7df5-ca5d-feadbfc949a5-fc4dcd5d" class="max-width-large">
                  <div fs-toc-element="contents" class="text-rich-text w-richtext">
                    <h4>{data.content.title}</h4>
                    <p><em>Last updated: {data.content.last_updated}</em></p>
                    <Fragment set:html={marked.parse(data.content.body)} />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
</BaseLayout>
