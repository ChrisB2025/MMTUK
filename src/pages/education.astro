---
import BaseLayout from '../layouts/BaseLayout.astro';
import pageData from '../data/pages/education.json';
---

<BaseLayout title={pageData.meta.title} description={pageData.meta.description} currentPage="education">
<header class="section_header54 text-color-white">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="header54_component">
                <div class="max-width-large">
                  <div class="margin-bottom margin-small">
                    <h1 class="heading-style-h1">{pageData.hero.heading}</h1>
                  </div>
                  <p class="text-size-medium-2 is-dark">{pageData.hero.tagline}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="header54_background-image-wrapper">
          <div class="image-overlay-layer"></div><img loading="eager" src="/images/hands-up.avif" alt="" class="header54_background-image">
        </div>
      </header>
      <header class="section_header2">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="header2_component">
                <div class="w-layout-grid header2_content">
                  <div class="header2_content-left">
                    <div class="margin-bottom margin-small">
                      <h2 class="heading-style-h2 left">{pageData.library.heading}</h2>
                    </div>
                    <p class="text-size-medium-21">{pageData.library.body}</p>
                    <div class="margin-top margin-medium">
                      <p class="text-size-medium text-weight-semibold" style="color: #666;">{pageData.library.coming_soon_label}</p>
                    </div>
                  </div>
                  <div class="header2_image-wrapper"><img loading="eager" src="/images/Ask-a-question.avif" alt="" class="header2_image"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>
      <div id="WhatIsMMT" class="padding-global">
        <div class="container-large">
          <div class="divider-horizontal page_divider"></div>
        </div>
      </div>
      <section class="section_faq7 color-scheme-4">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="faq7_component">
                <div class="text-align-center">
                  <div class="max-width-large align-center">
                    <div class="margin-bottom margin-small">
                      <h2 class="heading-style-h2 left">{pageData.what_is_mmt.heading}</h2>
                    </div>
                  </div>
                </div>
                <div class="max-width-large align-center">
                  <p class="text-size-medium" style="text-align: left; margin-bottom: 1.5rem;">{pageData.what_is_mmt.paragraph_1}</p>
                  <p class="text-size-medium" style="text-align: left; margin-bottom: 1.5rem;">{pageData.what_is_mmt.paragraph_2}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <div id="mmt-core-insights" class="padding-global">
        <div class="container-large">
          <div class="divider-horizontal page_divider"></div>
        </div>
      </div>
      <section class="section_faq7 color-scheme-4">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="faq7_component">
                <div class="margin-bottom margin-xxlarge">
                  <div class="text-align-center">
                    <div class="max-width-large align-center">
                      <h2 class="heading-style-h2 left">{pageData.core_insights.heading}</h2>
                    </div>
                  </div>
                </div>
                <div>
                  {pageData.core_insights.items.map((item) => (
                    <div class="accordion1_component">
                      <div class="accordion1_top">
                        <div class="text-size-medium-22 text-weight-bold">{item.title}</div>
                        <div class="accordion1_icon w-embed"><svg width="100%" height="100%" viewbox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M16.5303 20.8839C16.2374 21.1768 15.7626 21.1768 15.4697 20.8839L7.82318 13.2374C7.53029 12.9445 7.53029 12.4697 7.82318 12.1768L8.17674 11.8232C8.46963 11.5303 8.9445 11.5303 9.2374 11.8232L16 18.5858L22.7626 11.8232C23.0555 11.5303 23.5303 11.5303 23.8232 11.8232L24.1768 12.1768C24.4697 12.4697 24.4697 12.9445 24.1768 13.2374L16.5303 20.8839Z" fill="currentColor"></path>
                          </svg></div>
                      </div>
                      <div style="height:0px" class="accordion1_bottom">
                        <div class="margin-bottom margin-small" style="display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem;">
                          <p style="margin: 0;">{item.body}</p>
                          <a href={item.link_href} class="button is-link is-icon w-inline-block" style="flex-shrink: 0;">
                            <div>Read more</div>
                            <div class="icon-embed-xxsmall w-embed"><svg width="16" height="16" viewbox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M6 3L11 8L6 13" stroke="CurrentColor" stroke-width="1.5"></path>
                            </svg></div>
                          </a>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <div id="but-what-about" class="padding-global">
        <div class="container-large">
          <div class="divider-horizontal page_divider"></div>
        </div>
      </div>
      <section class="section_faq7 color-scheme-2">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="faq7_component">
                <div class="margin-bottom margin-xxlarge">
                  <div class="text-align-center">
                    <div class="max-width-large align-center">
                      <div class="margin-bottom margin-small">
                        <h2 class="heading-style-h2 left">{pageData.objections.heading}</h2>
                      </div>
                      <p class="text-size-medium approach">{pageData.objections.description}</p>
                    </div>
                  </div>
                </div>
                <div>
                  {pageData.objections.items.map((item) => (
                    <div class="accordion1_component">
                      <div class="accordion1_top">
                        <div class="text-size-medium-22 text-weight-bold">{item.title}</div>
                        <div class="accordion1_icon w-embed"><svg width="100%" height="100%" viewbox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M16.5303 20.8839C16.2374 21.1768 15.7626 21.1768 15.4697 20.8839L7.82318 13.2374C7.53029 12.9445 7.53029 12.4697 7.82318 12.1768L8.17674 11.8232C8.46963 11.5303 8.9445 11.5303 9.2374 11.8232L16 18.5858L22.7626 11.8232C23.0555 11.5303 23.5303 11.5303 23.8232 11.8232L24.1768 12.1768C24.4697 12.4697 24.4697 12.9445 24.1768 13.2374L16.5303 20.8839Z" fill="currentColor"></path>
                          </svg></div>
                      </div>
                      <div style="height:0px" class="accordion1_bottom">
                        <div class="margin-bottom margin-small" style="display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem;">
                          <p style="margin: 0;">{item.body}</p>
                          <a href={item.link_href} class="button is-link is-icon w-inline-block" style="flex-shrink: 0;">
                            <div>Read more</div>
                            <div class="icon-embed-xxsmall w-embed"><svg width="16" height="16" viewbox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M6 3L11 8L6 13" stroke="CurrentColor" stroke-width="1.5"></path>
                            </svg></div>
                          </a>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <div id="AdvisoryServices" class="padding-global">
        <div class="container-large">
          <div class="divider-horizontal page_divider"></div>
        </div>
      </div>
      <section class="section_faq7 color-scheme-4">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="faq7_component">
                <div class="text-align-center">
                  <div class="max-width-large align-center">
                    <div class="margin-bottom margin-small">
                      <h2 class="heading-style-h2 left">{pageData.advisory_services.heading}</h2>
                    </div>
                  </div>
                </div>
                <div class="max-width-large align-center">
                  <p class="text-size-medium" style="text-align: left; margin-bottom: 1.5rem;">
                    {pageData.advisory_services.paragraph_1}
                  </p>
                  <p class="text-size-medium" style="text-align: left;">
                    Our services include workshops, training sessions, policy review and ongoing advisory relationships, each designed to build internal capacity and inform evidence-based decision-making. If you are interested in working with us, please email us at <a href="#" class="text-style-link obfuscated-email" data-user="contact" data-domain="mmtuk.org"><span class="email-fallback">contact [at] mmtuk [dot] org</span></a>.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.obfuscated-email').forEach(function(el) {
      var user = el.getAttribute('data-user');
      var domain = el.getAttribute('data-domain');
      if (user && domain) {
        var email = user + '@' + domain;
        el.href = 'mailto:' + email;
        el.innerHTML = email;
      }
    });
  });
</script>
</BaseLayout>
