---
import BaseLayout from '../layouts/BaseLayout.astro';
import pageData from '../data/pages/founders.json';
---

<BaseLayout title={pageData.meta.title} description={pageData.meta.description} currentPage="founders">
<header class="section_header54 text-color-white">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="header54_component">
                <div class="max-width-large">
                  <div class="margin-bottom margin-small">
                    <h1 class="heading-style-h1">{pageData.hero.heading}</h1>
                  </div>
                  <p class="text-size-medium-2">{pageData.hero.subtitle}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="header54_background-image-wrapper">
          <div class="image-overlay-layer"></div><img sizes="(max-width: 2400px) 100vw, 2400px" srcset="/images/matt-seymour-RI1x1DpqEH4-unsplash-p-500.avif 500w, images/matt-seymour-RI1x1DpqEH4-unsplash-p-800.avif 800w, images/Donate-decoration.avif 2400w" alt="" src="/images/Donate-decoration.avif" loading="eager" class="header54_background-image">
        </div>
      </header>
      <section class="section_founder-member-scheme_feature-1">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="founder-member-scheme_feature-1_component">
                <div class="w-layout-grid founder-member-scheme_feature-1_content">
                  <div class="founder-member-scheme_feature-1_image-wrapper"><img sizes="(max-width: 2400px) 100vw, 2400px" srcset="/images/diana-light-lK_nxI17h-U-unsplash-p-500.avif 500w, images/diana-light-lK_nxI17h-U-unsplash-p-800.avif 800w, images/diana-light-lK_nxI17h-U-unsplash-p-1080.avif 1080w, images/envelopes.avif 2400w" alt="" src="/images/envelopes.avif" loading="lazy" class="founder-member-scheme_feature-1_image"></div>
                  <div id="w-node-aad54c2f-4c8b-ac28-10f0-6f6848906d09-8df9ac5d" class="founder-member-scheme_feature-1_content-right">
                    <div class="margin-bottom margin-xsmall">
                      <div class="text-style-tagline">{pageData.feature_1.tag}</div>
                    </div>
                    <div class="margin-bottom margin-small">
                      <h2 class="heading-style-h2-6">{pageData.feature_1.heading}</h2>
                    </div>
                    <p class="text-size-medium-2">{pageData.feature_1.description}</p>
                    <div class="margin-top margin-medium"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <header class="section_founder-member-scheme_feature-2">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="founder-member-scheme_feature-2_component">
                <div class="w-layout-grid founder-member-scheme_feature-2_content">
                  <div class="founder-member-scheme_feature-2_title-wrapper">
                    <div class="margin-bottom margin-medium"></div>
                    <div class="margin-bottom margin-small">
                      <h1 class="heading-style-h2-6">{pageData.feature_2.heading}</h1>
                    </div>
                    <div class="margin-top margin-small">
                      <div class="founder-member-scheme_feature-2_details-wrapper">
                        <div class="tag">
                          <div>{pageData.feature_2.tag}</div>
                        </div>
                        <div class="text-size-medium-2 text-weight-semibold">{pageData.feature_2.date}</div>
                      </div>
                    </div>
                    <div class="margin-top margin-medium">
                      <div class="founder-member-scheme_feature-2_countdown" id="founder-countdown" data-target={pageData.feature_2.countdown_target}>
                        <div class="founder-member-scheme_feature-2_number-wrapper">
                          <div id="days" class="heading-style-h3">45</div>
                          <div>Days</div>
                        </div>
                        <div class="divider-vertical"></div>
                        <div class="founder-member-scheme_feature-2_number-wrapper">
                          <div id="hours" class="heading-style-h3">12</div>
                          <div>Hours</div>
                        </div>
                        <div class="divider-vertical"></div>
                        <div class="founder-member-scheme_feature-2_number-wrapper">
                          <div id="minutes" class="heading-style-h3">44</div>
                          <div>Mins</div>
                        </div>
                        <div class="divider-vertical"></div>
                        <div class="founder-member-scheme_feature-2_number-wrapper">
                          <div id="seconds" class="heading-style-h3">29</div>
                          <div>Secs</div>
                        </div>
                        <div class="founder-member-scheme_feature-2_number-changes w-embed w-script"><!--  This script is managed by Consent Pro  -->
                          <script fs-consent-categories="marketing" fs-consent-scripttype="text/javascript" type="fs-consent">
(function () {
  const second = 1000,
    minute = second * 60,
    hour = minute * 60,
    day = hour * 24;
  const targetDateString = document.getElementById('founder-countdown').dataset.target;
  const targetDate = new Date(targetDateString).getTime();
  const updateCountdown = () => {
    const now = new Date().getTime(),
      distance = targetDate - now;
    document.getElementById('days').innerText = Math.floor(distance / day);
    document.getElementById('hours').innerText = Math.floor((distance % day) / hour);
    document.getElementById('minutes').innerText = Math.floor((distance % hour) / minute);
    document.getElementById('seconds').innerText = Math.floor((distance % minute) / second);
    if (distance < 0) {
      clearInterval(interval);
      document.getElementById('days').innerText = '0';
      document.getElementById('hours').innerText = '0';
      document.getElementById('minutes').innerText = '0';
      document.getElementById('seconds').innerText = '0';
      document.getElementById('message').style.display = 'block';
    }
  };
  updateCountdown();
  const interval = setInterval(updateCountdown, 1000);
})();
</script>
                        </div>
                      </div>
                    </div>
                    <div class="margin-top margin-medium">
                      <div class="founder-member-scheme_feature-2_form-block w-form">
                        <div class="form_message-success-wrapper w-form-done">
                          <div class="form_message-success">
                            <div>{pageData.feature_2.form_success_message}</div>
                          </div>
                        </div>
                        <div class="form_message-error-wrapper w-form-fail">
                          <div class="form_message-error">
                            <div>{pageData.feature_2.form_error_message}</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="founder-member-scheme_cta_plan">
                    <div class="founder-member-scheme_cta_content-top">
                      <div class="founder-member-scheme_cta_top-left">
                        <div class="margin-bottom margin-xxsmall">
                          <div class="heading-style-h5">{pageData.feature_2.tier_label}</div>
                        </div>
                        <div>{pageData.feature_2.tier_description}</div>
                      </div>
                      <div class="founder-member-scheme_cta_top-right">
                        <div class="heading-style-h2 heading-join">{pageData.feature_2.tier_price}</div>
                      </div>
                    </div>
                    <div class="margin-vertical margin-medium">
                      <div class="divider-horizontal"></div>
                    </div>
                    <div class="margin-bottom margin-xsmall"></div>
                    <div class="margin-vertical margin-medium"></div>
                    <a href="#" class="button-2 max-width-full w-button">{pageData.feature_2.button_label}</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>
      <section id="Founder-member-donate" class="section_founder-member-scheme_cta">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="w-layout-grid founder-member-scheme_cta_component">
                <div class="founder-member-scheme_cta_content-left">
                  <div class="margin-bottom margin-small">
                    <h2 class="heading-style-h2-6">{pageData.cta_section.heading}</h2>
                  </div>
                  <div class="margin-bottom margin-large">
                    <p class="text-size-medium-2">{pageData.cta_section.description}</p>
                  </div>
                  <div class="founder-member-scheme_cta_logo-wrapper">
                    <div class="margin-bottom margin-xxsmall">
                      <h3 class="heading-style-h6">{pageData.cta_section.trust_label}</h3>
                    </div>
                  </div>
                </div>
                <div class="founder-member-scheme_cta_plan">
                  <div class="founder-member-scheme_cta_content-top">
                    <div class="founder-member-scheme_cta_top-left">
                      <div class="margin-bottom margin-xxsmall">
                        <div class="heading-style-h5">{pageData.cta_section.tier_label}</div>
                      </div>
                      <div>{pageData.cta_section.tier_description}</div>
                    </div>
                    <div class="founder-member-scheme_cta_top-right">
                      <div class="heading-style-h2 heading-join">{pageData.cta_section.tier_price}</div>
                    </div>
                  </div>
                  <div class="margin-vertical margin-medium">
                    <div class="divider-horizontal"></div>
                  </div>
                  <div class="margin-bottom margin-xsmall"></div>
                  <div class="margin-vertical margin-medium"></div>
                  <a href="#" class="button-2 max-width-full w-button">{pageData.cta_section.button_label}</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="section_founder-member-scheme_testimonial">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="founder-member-scheme_testimonial_component">
                <div data-delay="4000" data-animation="slide" class="founder-member-scheme_testimonial_slider w-slider" data-autoplay="false" data-easing="ease" data-hide-arrows="false" data-disable-swipe="false" data-autoplay-limit="0" data-nav-spacing="3" data-duration="500" data-infinite="true">
                  <div class="founder-member-scheme_testimonial_mask w-slider-mask">
                    {pageData.testimonials.items.map((t) => (
                      <div class="founder-member-scheme_testimonial_slide w-slide">
                        <div class="founder-member-scheme_testimonial_content">
                          <div class="margin-bottom margin-medium">
                            <div class="founder-member-scheme_testimonial_logo-wrapper"></div>
                          </div>
                          <h3 class="heading-style-h5">{t.quote}</h3>
                          <div class="margin-top margin-medium">
                            <div class="founder-member-scheme_testimonial_client">
                              <div class="margin-bottom margin-xsmall">
                                <div class="founder-member-scheme_testimonial_client-image-wrapper"><img loading="lazy" src="https://uploads-ssl.webflow.com/624380709031623bfe4aee60/6243807090316203124aee66_placeholder-image.svg" alt="" class="founder-member-scheme_testimonial_client-image"></div>
                              </div>
                              <div class="text-weight-semibold">{t.name}</div>
                              <div>{t.role}</div>
                            </div>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div class="slider-arrow is-centre-previous hide-mobile-landscape w-slider-arrow-left">
                    <div class="slider-arrow-icon_default w-embed"><svg width="100%" height="100%" viewbox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3.31066 8.75001L9.03033 14.4697L7.96967 15.5303L0.439339 8.00001L7.96967 0.469676L9.03033 1.53034L3.31066 7.25001L15.5 7.25L15.5 8.75L3.31066 8.75001Z" fill="currentColor"></path>
                      </svg></div>
                  </div>
                  <div class="slider-arrow is-centre-next hide-mobile-landscape w-slider-arrow-right">
                    <div class="slider-arrow-icon_default w-embed"><svg width="100%" height="100%" viewbox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12.6893 7.25L6.96967 1.53033L8.03033 0.469666L15.5607 8L8.03033 15.5303L6.96967 14.4697L12.6893 8.75H0.5V7.25H12.6893Z" fill="currentColor"></path>
                      </svg></div>
                  </div>
                  <div class="founder-member-scheme_testimonial_slide-nav w-slider-nav w-slider-nav-invert w-round"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="section_founder-member-scheme_faq">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="founder-member-scheme_faq_component">
                <div class="margin-bottom margin-xxlarge">
                  <div class="text-align-center">
                    <div class="max-width-large align-center">
                      <div class="margin-bottom margin-small">
                        <h2 class="heading-style-h2-6">{pageData.faq.heading}</h2>
                      </div>
                      <p class="text-size-medium-2">{pageData.faq.intro}</p>
                    </div>
                  </div>
                </div>
                <div class="max-width-large align-center">
                  <div class="founder-member-scheme_faq_list">
                    {pageData.faq.items.map((item) => (
                      <div class="founder-member-scheme_faq_item">
                        <div class="margin-bottom margin-xsmall">
                          <div class="text-size-medium-2 text-weight-bold">{item.question}</div>
                        </div>
                        <p>{item.answer}</p>
                      </div>
                    ))}
                  </div>
                </div>
                <div class="margin-top margin-xxlarge">
                  <div class="text-align-center">
                    <div class="max-width-medium align-center">
                      <div class="margin-bottom margin-xsmall">
                        <h3 class="heading-style-h4">{pageData.faq.contact_heading}</h3>
                      </div>
                      <p class="text-size-medium-2">{pageData.faq.contact_intro}</p>
                      <div class="margin-top margin-medium">
                        <div class="button-group is-center faq">
                          <div class="contact15_item">
                            <div class="contact15_item-icon-wrapper">
                              <div class="icon-embed-xsmall w-embed"><svg width=" 100%" height=" 100%" viewbox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                  <path d="M20 4H4C2.897 4 2 4.897 2 6V18C2 19.103 2.897 20 4 20H20C21.103 20 22 19.103 22 18V6C22 4.897 21.103 4 20 4ZM20 6V6.511L12 12.734L4 6.512V6H20ZM4 18V9.044L11.386 14.789C11.5611 14.9265 11.7773 15.0013 12 15.0013C12.2227 15.0013 12.4389 14.9265 12.614 14.789L20 9.044L20.002 18H4Z" fill="currentColor"></path>
                                </svg></div>
                            </div>
                            <div class="contact15_item-text-wrapper">
                              <a href="mailto:contact@mmtuk.org?subject=contact%40mmtuk.org" class="text-style-link">contact@mmtuk.org</a>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
</BaseLayout>
