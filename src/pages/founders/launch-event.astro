---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Launch Event: A Counter-Inflationary Job Guarantee for Britain"
  description="Recording and programme from the MMTUK launch event, 25 February 2026 at Friends House, London."
  noindex={true}
>
  <header class="section_blog-post5-header">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-article-title">
          <div class="blog-post5-pagetitle-wrapper">
            <div class="margin-bottom">
              <h1 class="heading-style-h3">Launch Event: A Counter-Inflationary Job Guarantee for Britain</h1>
            </div>
            <p class="text-size-medium">25 February 2026 &middot; Friends House, London</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <header class="section_blog-post5-content">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-bottom padding-xhuge">
          <div class="blog-post5-content_component">

            <div class="blog-post5-content_content-left">
              <div class="blog-post5-header-wrapper">
                <div class="blog-post5-titlesmall-wrapper">
                  <h6 class="heading-6">Founder Members</h6>
                </div>
                <div class="div-block-8">
                  <div class="text-size-small-5">Date</div>
                  <div class="blog-post5-header_date">25 February 2026</div>
                </div>
                <div class="div-block-8">
                  <div class="text-size-small-5">Venue</div>
                  <div class="blog-post5-header_date">Friends House, London</div>
                </div>
                <div class="margin-bottom margin-medium">
                  <div class="button-group">
                    <a href="/docs/launch-event-transcript.pdf"
                       class="button-2 is-link is-icon"
                       download
                       data-umami-event="launch-event-transcript-download">
                      <div>Download full transcript (PDF)</div>
                    </a>
                  </div>
                </div>
              </div>
              <div class="blog-post5-content_divider"></div>
            </div>

            <div class="blog-post5-content_content">

              <div class="blog-post5-header_image-wrapper" style="padding:56.25% 0 0 0;position:relative;">
                <iframe
                  id="launch-event-video"
                  src="https://player.vimeo.com/video/1169129147?h=897742445e&amp;badge=0&amp;autopause=0&amp;player_id=0&amp;app_id=58479"
                  allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;border-radius:8px;"
                  title="MMTUK Launch Event – A Counter-Inflationary Job Guarantee for Britain">
                </iframe>
              </div>
              <script src="https://player.vimeo.com/api/player.js"></script>
              <script is:inline>
                document.addEventListener('DOMContentLoaded', function() {
                  var iframe = document.getElementById('launch-event-video');
                  if (!iframe || typeof Vimeo === 'undefined') return;
                  var player = new Vimeo.Player(iframe);
                  player.on('play', function() {
                    if (typeof umami !== 'undefined') umami.track('launch-event-video-play');
                    player.off('play');
                  });
                });
              </script>

              <div class="text-rich-text w-richtext">
                <p>Thank you for your support as a founder member. Below you will find the full video recording and transcript of our launch event.</p>

                <h3>Programme</h3>
                <ul role="list">
                  <li><strong>Opening Remarks</strong> &mdash; Randeep Ramesh, The Guardian</li>
                  <li><strong>Statement from GIMMS</strong> &mdash; Prue Plumridge</li>
                  <li><strong>MMTUK Mission &amp; Vision</strong> &mdash; Patricia Pino</li>
                  <li><strong>Message from L. Randall Wray</strong> &mdash; Read by David Merrill</li>
                  <li><strong>A Counter-Inflationary Job Guarantee for Britain</strong> &mdash; Patricia Pino</li>
                  <li><strong>Keynote Address</strong> &mdash; Prof Bill Mitchell</li>
                  <li><strong>Panel Q&amp;A</strong> &mdash; All speakers</li>
                </ul>
              </div>

            </div>

          </div>
        </div>
      </div>
    </div>
  </header>
</BaseLayout>
